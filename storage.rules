// ============================================================
//  SAATHI CARE — Firebase Storage Rules
//  Paste into Firebase Console → Storage → Rules
// ============================================================

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Gallery images — readable by all, writable by logged-in caregivers
    // Max 5MB per file, images only
    match /gallery/{caregiverId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == caregiverId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.uid == caregiverId;
    }
  }
}
